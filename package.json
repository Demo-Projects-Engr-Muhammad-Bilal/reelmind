{
  "name": "aireelgen-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "workers/*",
    "packages/*"
  ],
  "scripts": {
    "prisma:merge": "node scripts/merge-prisma.js",
    "prisma:generate:root": "npm run prisma:merge && prisma generate --schema=packages/database/prisma/schema.prisma",
    "prisma:generate:admin": "npm run prisma:merge && prisma generate --schema=apps/admin/prisma/schema.prisma"
  },
  "devDependencies": {
    "turbo": "^1.13.0"
  }
}