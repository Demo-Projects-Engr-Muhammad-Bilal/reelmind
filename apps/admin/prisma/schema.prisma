// schema.prisma
generator client {
  provider = "prisma-client-js"
  binaryTargets = ["debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  email             String    @unique
  name              String?
  password          String
  credits           Int       @default(50)
  isVerified        Boolean   @default(false)
  verifyToken       String?   @unique
  verifyTokenExpiry DateTime?
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?
  currentSessionId String?  
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  reels             Reel[]
  telegramId        String?   @unique 
  telegramCreds     TelegramCredentials?
}

// 🤖 STANDALONE TELEGRAM CREDENTIALS MODEL
model TelegramCredentials {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @unique @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  telegramChatId String   @unique // Core dynamic identifier: user aur bot ke beech ki chat session ID
  username       String?  // User ka telegram handle username (@username)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Scene {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  reelId         String   @db.ObjectId
  reel           Reel     @relation(fields: [reelId], references: [id], onDelete: Cascade)
  order          Int      
  visualPrompt   String   // Image generate karne ke liye
  videoPrompt    String?  // 🤖 Naya: Veo AI ko motion samjhane ke liye
  audioText      String   
  voiceoverUrl   String?  
  imagePath      String?  
  videoPath      String?  // 🎬 Naya: Final .mp4 file ka path
  audioDuration  Float?   
  createdAt      DateTime @default(now())
  creditsSpent   Int      @default(0)
}


model Reel {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  userId            String   @db.ObjectId 
  user              User     @relation(fields: [userId], references: [id])
  topic             String
  style             String   // Niche key store hoti hai yahan
  status            String   @default("GENERATING")
  winnerScript      Json?
  hooks             Json?    
  scenes            Scene[]
  videoUrl          String?  // Final video path save karne ke liye
  localFallbackPath String?  // 📁 Temporary local download path caching ke liye
  isPublic          Boolean  @default(false) // ⚡ NEW: Gallery visibility flag
  createdAt         DateTime @default(now())
  totalCreditsSpent Int      @default(0)
}

model Niche {
  id                   String   @id @default(auto()) @map("_id") @db.ObjectId
  key                  String   @unique 
  name                 String   
  systemPrompt         String   
  hooksInstruction     String   
  expansionInstruction String   
  imageInstruction     String?  
  audioInstruction     String? 
  videoInstruction     String?
  bgmUrls              String[] 
  bgmVolume            Float?   @default(0.2) 
  fallbackUrl          String?  
  createdAt            DateTime @default(now())
}

// 💸 PAY-AS-YOU-GO LEDGER MODEL
model UsageLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  reelId    String   @db.ObjectId
  stage     String   // "AUDIO" | "IMAGE" | "VIDEO" | "UTILITY"
  provider  String   // e.g., "gemini-flash", "google-tts", "static-fallback-cached"
  cost      Int      // Safe rounded integers deduction tracking
  createdAt DateTime @default(now())
}


// 💸 DYNAMIC PAY-AS-YOU-GO PRICING CONFIGURATION
model PricingRate {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  stage     String   // "AUDIO" | "IMAGE" | "VIDEO" | "UTILITY"
  provider  String   @unique // e.g., "google-tts", "gemini-flash"
  rate      Float    // Base credit rate per calculation unit
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



// ⚡ NEW: Dynamic Payment Packages
model CreditPackage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  planId    String   @unique // Yeh frontend se aayega (e.g., "starter", "pro", "agency")
  name      String
  credits   Int
  priceUSD  Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}



model Admin {
  id                 String    @id @default(auto()) @map("_id") @db.ObjectId
  email              String    @unique
  password           String    // Hashed password
  name               String?
  role               String    @default("SUPER_ADMIN")
  
  // ⚡ Authentication & Security Fields
  twoFactorSecret    String?   // TOTP secret for Microsoft Authenticator
  isTwoFactorEnabled Boolean   @default(false)
  resetToken         String?   // For Forgot Password link
  resetTokenExpiry   DateTime? // Token expiration time
  currentSessionId   String?
  
  // ⚡ Audit Metrics
  lastLoginAt        DateTime? 
  lastPasswordChange DateTime? 
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}