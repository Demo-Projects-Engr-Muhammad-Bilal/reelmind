{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",
    "module": "node16",
    "moduleResolution": "node16",
    "target": "ES2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true
  },
  "include": ["*.ts", "prisma/*.ts"],
  "exclude": ["node_modules", "dist"]
}